{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Compañero Voice Spike",
  "version": "0.0.0",
  "identifier": "dev.wuju.companero.voice-spike",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev",
    "devUrl": "http://localhost:3000/companion",
    "frontendDist": "../../apps/web/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "El Compañero Voice Spike",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
