{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Disposable voice spike permissions for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "mic-recorder:default",
    "fs:allow-read-file",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": ["$APPDATA/tauri-plugin-mic-recorder/*", "$APPDATA/tauri-plugin-mic-recorder/**"]
    }
  ]
}
