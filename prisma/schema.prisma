// Fuente de verdad: docs/CONTRATOS.md sección "Modelo de datos (Prisma)"

generator client {
  provider        = "prisma-client-js"
  // Fase 8 de DESKTOP-MIGRATION-PLAN.md: memoria semántica. Prisma no tiene tipo
  // nativo para pgvector — se modela como Unsupported("vector(N)") y las queries
  // de similitud van por $queryRaw, no por el Client normal.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  sessions   Session[]
  characters Character[]
  orders     Order[]
  ownerships Ownership[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Character {
  id        String   @id @default(cuid())
  userName  String   @unique
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  hairId      String?
  eyesId      String?
  mouthId     String?
  accessoryId String?
  clothingId  String?

  personality String @default("amigable")
  voiceId     String @default("21m00Tcm4TlvDq8ikWAM")

  coins Int @default(1000) // saldo de monedas de demo (moneda in-app, no dinero real)

  messages                  Message[]
  inventory                 InventoryItem[]
  skills                    ActiveSkill[]
  memories                  MemoryEntry[]
  savedMarketplaceCharacters SavedMarketplaceCharacter[]
}

// Traído de la rama de rebrand (main), adaptado a auth vieja: se liga a
// characterId, no a un userId 1:1 (ese modelo de auth se rechazó explícitamente).
model SavedMarketplaceCharacter {
  id                     String   @id @default(cuid())
  characterId            String
  marketplaceCharacterId String // id lógico del personaje del marketplace (ej. "policia")
  name                   String
  category               String
  categoryId             String
  image                  String
  tag                    String
  tagTone                String
  background             String
  isNew                  Boolean  @default(false)
  isPopular              Boolean  @default(false)
  savedAt                DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, marketplaceCharacterId])
  @@index([characterId])
}

model Part {
  id        String  @id @default(cuid())
  category  String // 'hair' | 'eyes' | 'mouth' | 'accessory' | 'clothing'
  name      String
  imageUrl  String // /parts/hair-rizado.png
  isPremium Boolean @default(false)
  price     Int     @default(0)

  inventoryItems InventoryItem[]
}

model InventoryItem {
  id          String   @id @default(cuid())
  characterId String
  partId      String
  acquiredAt  DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])
  part      Part      @relation(fields: [partId], references: [id])

  @@unique([characterId, partId])
}

model Message {
  id          String   @id @default(cuid())
  characterId String
  role        String // 'user' | 'assistant'
  content     String
  skillUsed   String? // 'code-guardian' | 'chat-base'
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])
}

model ActiveSkill {
  id          String   @id @default(cuid())
  characterId String
  skillKey    String // 'chat-base' | 'code-guardian'
  enabledAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])

  @@unique([characterId, skillKey])
}

// ── Marketplace: catálogo vendible ─────────────────────────────────────────

model CharacterTemplate {
  id         String  @id @default(cuid())
  key        String  @unique // 'purr-fect', 'byte-warden', ...
  name       String
  role       String
  summary    String
  avatar     String // iniciales o emoji mostrado en la tarjeta
  personality String @default("amigable")
  // Fase 7.1 de DESKTOP-MIGRATION-PLAN.md: personalidad como producto de marketplace.
  // Texto libre de un creador externo — capa CONFIGURABLE del system prompt, nunca
  // reemplaza el núcleo inmutable de reglas de lib/ai.ts. Requiere curaduría antes de
  // publicar (riesgo de prompt injection vía marketplace, ver DESKTOP-MIGRATION-PLAN.md
  // sección 7.1). Null = personaje usa el mapa fijo de `personality` como hasta ahora.
  personalityPrompt String?
  voiceId    String
  voiceLabel String
  statsJson  String // {"analysis":85,"creativity":62,"speed":94}
  priceCents Int     @default(0) // 0 = gratis; pago simulado, sin dinero real todavía
  isPremium  Boolean @default(false)
}

model Pack {
  id          String  @id @default(cuid())
  key         String  @unique // 'desarrollo', 'marketing', ...
  name        String
  description String
  skillsJson  String // ["chat-base","code-guardian"]
  priceCents  Int     @default(0)
  isPremium   Boolean @default(false)
  available   Boolean @default(true) // false = "próximamente" en el marketplace
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  totalCents Int
  status     String // 'paid_simulated' — no hay pasarela real todavía
  createdAt  DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productType String // 'part' | 'character' | 'pack'
  productId   String
  name        String
  priceCents  Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Ownership {
  id          String   @id @default(cuid())
  userId      String
  productType String // 'part' | 'character' | 'pack'
  productId   String
  acquiredAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, productType, productId])
}

// ── Fase 8 (DESKTOP-MIGRATION-PLAN.md): memoria semántica ──────────────────
// Hechos DESTILADOS del usuario (no transcripts crudos), extraídos async post-turno
// por un modelo barato. El Context Builder hace similarity search acá antes de armar
// el system prompt (Etapa C). Explícitamente pospuesto para el MVP web (CLAUDE.md:
// "memoria es JSON simple") — esto es evolución de la capa desktop, no del MVP.
model MemoryEntry {
  id          String   @id @default(cuid())
  characterId String
  content     String // hecho destilado, ej: "prefiere respuestas cortas"
  kind        String // 'fact' | 'preference' | 'event'
  // pgvector no tiene tipo nativo en Prisma Client — Unsupported() lo excluye de
  // los queries generados; se opera por SQL crudo (ver nota de migración).
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}
