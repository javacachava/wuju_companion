# Base de datos
# PostgreSQL. Local: `docker compose up -d postgres` o `./scripts/pg-local.sh install` (sin Docker).
# Equipo/producción: Supabase — usar el SESSION POOLER (IPv4), no la conexión directa (es IPv6-only):
# postgresql://postgres.<ref>:<password-url-encoded>@aws-1-<region>.pooler.supabase.com:5432/postgres?schema=public
DATABASE_URL="postgresql://companero:companero@localhost:5432/companero?schema=public"

# DataMCP (opcional; solo para conectar Codex/Cursor/Claude a la DB vía MCP)
# DataMCP no reemplaza DATABASE_URL: se conecta al mismo PostgreSQL con permisos.
DATAMCP_MCP_URL=
DATAMCP_API_KEY=

# LLM
OPENAI_API_KEY=

# Voz
ELEVENLABS_API_KEY=

# n8n (opcional en dev)
N8N_WEBHOOK_URL=https://cachavacha.app.n8n.cloud/webhook
N8N_WEBHOOK_SECRET=replace-with-32-plus-random-chars

# Assets (solo Dev B)
FAL_API_KEY=

# App (en producción: https://<dominio-del-equipo>)
NEXT_PUBLIC_APP_URL=http://localhost:3000
