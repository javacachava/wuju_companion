# Base de datos
# En el VPS de producción usar una ruta absoluta persistente, ej: file:/var/lib/companero/prod.db
DATABASE_URL="file:./dev.db"

# LLM
OPENAI_API_KEY=

# Voz
ELEVENLABS_API_KEY=

# n8n (opcional en dev)
N8N_WEBHOOK_URL=https://cachavacha.app.n8n.cloud/webhook
N8N_WEBHOOK_SECRET=test

# Assets (solo Dev B)
FAL_API_KEY=

# App (en producción: https://<dominio-del-equipo>)
NEXT_PUBLIC_APP_URL=http://localhost:3000
