{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Compañero",
  "version": "0.1.0",
  "identifier": "dev.wuju.companero.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev",
    "devUrl": "http://localhost:3000/companion",
    "frontendDist": "https://companion.wuju.dev/companion"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "El Compañero",
        "url": "https://companion.wuju.dev/companion",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
