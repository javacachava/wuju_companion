{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capacidades del sistema operativo para la ventana principal — Fase 2 de DESKTOP-MIGRATION-PLAN.md.",
  "windows": ["main"],
  "remote": {
    "urls": ["https://companion.wuju.dev"]
  },
  "permissions": [
    "core:default",
    "mic-recorder:default",
    "clipboard-manager:allow-read-text",
    "screenshots:default",
    "fs:allow-read-file",
    "fs:allow-remove",
    "ocr-screenshot",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/tauri-plugin-mic-recorder/*",
        "$APPDATA/tauri-plugin-mic-recorder/**",
        "$APPDATA/tauri-plugin-screenshots/*",
        "$APPDATA/tauri-plugin-screenshots/**"
      ]
    }
  ]
}
